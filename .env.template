# MCP Server Configuration Template
# Standardized environment variables for cross-platform support

# The root directory for all skills
SKILLS_HOME=Agent_skills/skills

# API Keys (Do not commit actual keys to GitHub)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_claude_key_here

# Default Models
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Token Limits (Responses API)
# gpt-4o max: 16384, o1/o3: up to 100000
OPENAI_MAX_OUTPUT_TOKENS=16384

# LINE Bot Model Routing (LLM-as-a-Router)
# Set LINE_ROUTER_ENABLED=false to skip router and use LINE_MODEL_MINI as default
LINE_ROUTER_ENABLED=true
LINE_MODEL_ROUTER=gpt-4.1-nano
LINE_MODEL_NANO=gpt-4.1-nano
LINE_MODEL_MINI=gpt-4.1-mini
LINE_MODEL_FULL=gpt-4.1
LINE_MODEL_CHUNK_SUMMARY=gpt-4.1-mini
LINE_MODEL_CHUNK_FINAL=gpt-4.1

# Security Settings
STRICT_MODE=true
UMA_STREAMING_ENABLED=true
# Use native chat path first; unsupported scenarios will fallback to legacy bridge.
MCP_CHAT_NATIVE=false

# LINE Messaging API (Do not commit actual keys to GitHub)
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
